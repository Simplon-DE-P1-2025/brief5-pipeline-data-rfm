# Copier ce fichier en `.env` et adapter si besoin : `cp .env.example .env`

# --- Postgres (données métier + metadata Airflow) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=rfm

# --- Airflow ---
# UID local pour que les fichiers créés par Airflow appartiennent à ton user
# (récupérer avec: `id -u`)
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=changeme_generate_with_python_fernet
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Chemin ABSOLU vers le dossier `data` sur la machine HÔTE.
# Utilisé par DockerOperator pour monter le dataset dans le container ETL.
# Récupérer avec : `cd data && pwd`
HOST_DATA_PATH=/absolute/path/to/rfm-pipeline/data

# Nom du réseau Docker créé par compose. Format : <nom_du_dossier>_default
# Vérifier après un `docker compose up -d` avec : `docker network ls`
COMPOSE_NETWORK=rfm-pipeline_default
